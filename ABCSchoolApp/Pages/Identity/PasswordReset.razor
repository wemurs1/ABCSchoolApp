<MudForm @ref="_form" Model="ChangePasswordRequest">
    <MudCard Elevation="25">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText>Reset Password</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="ChangePasswordRequest.NewPassword" Variant="Variant.Outlined"
                                  InputType="_newPasswordVisible.InputType" Adornment="Adornment.End"
                                  AdornmentIcon="@_newPasswordVisible.InputIcon" Label="New Password"
                                  OnAdornmentClick="@(()=>TogglePasswordVisibility(_newPasswordVisible))" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="ChangePasswordRequest.ConfirmNewPassword" Variant="Variant.Outlined"
                                  InputType="_confirmPasswordVisible.InputType" Adornment="Adornment.End"
                                  AdornmentIcon="@_confirmPasswordVisible.InputIcon" Label="Confirm New Password"
                                  OnAdornmentClick="@(()=>TogglePasswordVisibility(_confirmPasswordVisible))" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="ChangePasswordRequest.CurrentPassword" Variant="Variant.Outlined"
                                  InputType="_currentPasswordVisible.InputType" Adornment="Adornment.End"
                                  AdornmentIcon="@_currentPasswordVisible.InputIcon" Label="Current Password"
                                  OnAdornmentClick="@(()=>TogglePasswordVisibility(_currentPasswordVisible))" />
                </MudItem>
            </MudGrid>
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="ml-auto"
                       OnClick="ResetPasswordAsync">
                Reset Password
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>