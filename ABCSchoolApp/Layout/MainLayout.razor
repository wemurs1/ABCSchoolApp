@using ABCSchoolApp.Components
@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh">
            <MudPaper Elevation="0" Class="py-4" Style="width: 500px">
                <MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
                    @Body
                </MudContainer>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
    <Authorized>
        <MudLayout>
            <MudAppBar>
                <MudText Typo="Typo.h6" Class="ml-2">School App</MudText>
                <MudIconButton Icon="@Icons.Material.Outlined.Menu" Class="ml-2" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="@((e)=>ToggleDrawer())" />
                <MudSpacer />
                <MudMenu Icon="@Icons.Material.Outlined.Person" Color="Color.Inherit"
                         TransformOrigin="Origin.BottomLeft" Dense="true" Class="mt-1 ml-4">
                    <ChildContent>
                        <CurrentUserCard />
                        <MudDivider />
                        <MudList T="string">
                            <MudListItem OnClick="LogoutDialog" Text="Logout" Icon="@Icons.Material.Filled.Logout">

                            </MudListItem>
                        </MudList>
                    </ChildContent>
                </MudMenu>
            </MudAppBar>
            <MudDrawer ClipMode="DrawerClipMode.Always" @bind-Open="_drawerOpen">
                <NavMenu />
            </MudDrawer>
            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.False" Class="mt-1">
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </Authorized>
</AuthorizeView>